model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  metadata    Json?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("feature_flags")
}

// --- Distributed Cron Locks ---
// Prevents duplicate cron job execution in multi-instance deployments.
// Each row represents a lock for a specific cron job. The lockedUntil
// column acts as both the lock flag and the automatic expiry.

model CronLock {
  id         String   @id
  lockedAt   DateTime @default(now())
  lockedUntil DateTime

  @@map("cron_locks")
}

// --- Password reset tokens ---
// Stores a hashed reset token per user with a bounded TTL. Tokens are single-use:
// `usedAt` is set when redeemed. We hash the token at rest so a DB leak does not
// let an attacker take over accounts.

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// One row per outstanding email-verification link. Same shape as
// PasswordResetToken / EmailChangeToken: tokenHash is SHA-256 of the
// raw token (never store raw), single-use via usedAt, time-bounded
// via expiresAt.
model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

// Email-change confirmation token. Sent to the NEW email address; redeeming
// it atomically swaps the user's email. Old tokens are invalidated when a
// new one is issued so a stolen link becomes useless as soon as the user
// restarts the flow.
model EmailChangeToken {
  id         String    @id @default(cuid())
  userId     String
  newEmail   String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("email_change_tokens")
}

enum TwoFaMethod {
  TOTP
  SMS
}

/// Dedup cache for inbound webhook deliveries. A given provider may
/// retry the same event several times (e.g. Mercado Pago redelivers
/// every 5 minutes until we return 2xx, and again on any 5xx). Without
/// a dedup guard that means double-credits on the wallet ledger.
///
/// We INSERT a row keyed on (provider, externalEventId) as the FIRST
/// step of the handler. The UNIQUE constraint on that pair rejects any
/// subsequent delivery with a P2002 that the handler treats as "already
/// processed, return 200 silently".
///
/// receivedAt is indexed so a daily sweep can drop rows older than 60
/// days; the dedup window only needs to cover the longest retry window
/// a provider uses.
model ProcessedWebhook {
  id              String   @id @default(cuid())
  provider        String   // 'mercadopago' | 'nfe' | future providers
  externalEventId String   // The provider's own id for the delivery
  action          String?  // Captured for audit (e.g. "payment.updated")
  receivedAt      DateTime @default(now())

  @@unique([provider, externalEventId])
  @@index([receivedAt])
}

// PIX key type, mirrors the Brazilian Banco Central classification.
enum PayoutMethodType {
  PIX_CPF
  PIX_CNPJ
  PIX_EMAIL
  PIX_PHONE
  PIX_RANDOM
}
