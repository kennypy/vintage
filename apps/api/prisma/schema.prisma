// ============================================================
// Vintage.br — Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Users ---

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  cpf                String?   @unique
  cnpj               String?   @unique
  cnpjVerified       Boolean   @default(false)
  name               String
  phone              String?
  avatarUrl          String?
  bio                String?
  verified           Boolean   @default(false)
  // Modulo-11 checksum validation — cheap, no vendor call. Set to true
  // at registration when the CPF digits produce a valid check digit.
  // Used to be named `cpfVerified`; renamed because "verified" was
  // misleading — a valid-check-digit CPF is NOT a verified identity.
  cpfChecksumValid   Boolean   @default(false)
  // True only after a Tier-2 / Tier-3 KYC provider (Serpro / Serasa /
  // idwall / Unico / Mercado Pago's own KYC callback) confirms that
  // (a) the CPF is ATIVO at Receita Federal, AND (b) the full name
  // on the account matches the CPF holder. Defaults false for every
  // new user until the KYC flow completes. Gates payout (see
  // payouts.service.ts) and NF-e issuance (nfe.client.ts).
  cpfIdentityVerified Boolean  @default(false)
  // Self-declared birth date. Required input for the Serpro
  // Datavalid CPF check (Receita matches on CPF + name + DOB).
  // Nullable so existing accounts don't break; KYC flow prompts
  // for it when missing.
  birthDate          DateTime? @db.Date
  twoFaEnabled       Boolean   @default(false)
  // Monotonically-incremented every time we need to globally invalidate
  // existing sessions for this user (email change, password change, admin
  // force-logout). Every issued JWT carries the ver claim at sign time; the
  // JWT auth guard rejects tokens whose ver ≠ current tokenVersion. Bumped
  // in the same DB transaction that commits the triggering change so a
  // window of valid tokens never exists after the event.
  tokenVersion       Int       @default(0)
  twoFaMethod        TwoFaMethod @default(TOTP) // TOTP authenticator app or SMS
  twoFaSecret        String?   // Encrypted TOTP secret (null when 2FA disabled or SMS)
  // Phone number verified for SMS 2FA. E.164 format (+55...). Separate from
  // `phone` because the profile phone may be displayed publicly while the
  // 2FA number is strictly an auth factor.
  twoFaPhone         String?
  twoFaPhoneVerifiedAt DateTime?
  socialProvider     String?   // 'google', 'apple', or null
  socialProviderId   String?   // provider's unique user ID
  coverPhotoUrl      String?
  vacationMode       Boolean   @default(false)
  vacationUntil      DateTime?
  role               UserRole  @default(USER)
  isBanned           Boolean   @default(false)
  bannedAt           DateTime?
  bannedReason       String?
  // Soft-delete / account deletion (LGPD + App Store / Play Store requirement)
  deletedAt          DateTime?
  // ToS / Privacy acceptance tracking (required at signup)
  acceptedTosAt      DateTime?
  acceptedTosVersion String?
  ratingAvg          Float     @default(0)
  ratingCount        Int       @default(0)
  followerCount      Int       @default(0)
  followingCount     Int       @default(0)
  // Email-ownership proof. Null means the user has not yet clicked the
  // link in the verification email we send at registration. Login paths
  // refuse password logins on unverified accounts (see auth.service.ts
  // login() + the EmailVerificationToken model below). Social-login
  // paths set this eagerly because Google / Apple vouch for the email.
  emailVerifiedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  emailVerificationTokens EmailVerificationToken[]
  listings          Listing[]
  ordersBuyer       Order[]             @relation("OrderBuyer")
  ordersSeller      Order[]             @relation("OrderSeller")
  offers            Offer[]
  wallet            Wallet?
  payoutMethods     PayoutMethod[]
  payoutRequests    PayoutRequest[]
  favorites         Favorite[]
  followersRel      Follow[]            @relation("Following")
  followingRel      Follow[]            @relation("Follower")
  conversationsAs1  Conversation[]      @relation("ConversationParticipant1")
  conversationsAs2  Conversation[]      @relation("ConversationParticipant2")
  messagesSent      Message[]
  reviewsWritten    Review[]            @relation("ReviewWriter")
  reviewsReceived   Review[]            @relation("ReviewReceiver")
  disputesOpened    Dispute[]
  notifications     Notification[]
  addresses         Address[]
  promotions        Promotion[]
  savedSearches     SavedSearch[]
  priceDropAlerts   PriceDropAlert[]
  deviceTokens           DeviceToken[]
  reports                Report[]
  loginEvents            LoginEvent[]
  authenticityRequests   AuthenticityRequest[]
  deletionAuditLogs      DeletionAuditLog[]
  blocksMade             UserBlock[]         @relation("UserBlocker")
  blocksReceived         UserBlock[]         @relation("UserBlocked")
  listingImageFlags      ListingImageFlag[]  @relation("ListingImageFlagUploader")
  listingImageFlagReviews ListingImageFlag[] @relation("ListingImageFlagReviewer")
  fraudFlags             FraudFlag[]         @relation("FraudFlagSubject")
  fraudFlagReviews       FraudFlag[]         @relation("FraudFlagReviewer")
  cpfVerificationLogs    CpfVerificationLog[]
  cafVerificationSessions CafVerificationSession[]

  @@index([email])
  @@index([cpf])
  @@index([socialProvider, socialProviderId])
  @@index([deletedAt])
}

// --- Listings ---

model Listing {
  id              String        @id @default(cuid())
  sellerId        String
  title           String
  description     String
  categoryId      String
  brandId         String?
  condition       ItemCondition
  size            String?
  color           String?
  priceBrl        Decimal       @db.Decimal(10, 2)
  shippingWeightG Int
  status          ListingStatus @default(ACTIVE)
  isAuthentic     Boolean       @default(false) // Set when authenticity request approved
  promotedUntil   DateTime?
  favoriteCount   Int           @default(0)
  viewCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  seller               User                  @relation(fields: [sellerId], references: [id])
  category             Category              @relation(fields: [categoryId], references: [id])
  brand                Brand?                @relation(fields: [brandId], references: [id])
  images               ListingImage[]
  videos               ListingVideo[]
  orders               Order[]
  offers               Offer[]
  favorites            Favorite[]
  bundleItems          BundleItem[]
  promotions           Promotion[]
  priceSuggestion      PriceSuggestion?
  priceDropAlerts      PriceDropAlert[]
  authenticityRequest  AuthenticityRequest?

  @@index([sellerId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([createdAt])
  @@index([priceBrl])
}

model ListingImage {
  id        String @id @default(cuid())
  listingId String
  url       String
  position  Int
  width     Int
  height    Int

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingVideo {
  id              String   @id @default(cuid())
  listingId       String
  url             String   // S3 URL for the video file
  thumbnailUrl    String?  // S3 URL for the auto-generated thumbnail
  durationSeconds Int?     // Duration in seconds (max 30)
  createdAt       DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId]) // One video per listing
  @@index([listingId])
}

// --- Categories & Brands ---

model Category {
  id       String  @id @default(cuid())
  parentId String?
  namePt   String
  slug     String  @unique
  icon     String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]

  @@index([parentId])
  @@index([slug])
}

model Brand {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  verified Boolean @default(false)

  listings Listing[]

  @@index([slug])
}

// --- Coupons ---

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  discountPct Int       // 0–100 (100 = free)
  maxUses     Int?      // null = unlimited
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  orders Order[]

  @@index([code])
}

// --- Orders ---

model Order {
  id                    String        @id @default(cuid())
  buyerId               String
  sellerId              String
  listingId             String
  status                OrderStatus   @default(PENDING)
  totalBrl              Decimal       @db.Decimal(10, 2)
  itemPriceBrl          Decimal       @db.Decimal(10, 2)
  shippingCostBrl       Decimal       @db.Decimal(10, 2)
  buyerProtectionFeeBrl Decimal       @db.Decimal(10, 2)
  discountBrl           Decimal?      @db.Decimal(10, 2)
  couponId              String?
  paymentMethod         PaymentMethod
  paymentId             String?
  shippingLabelUrl      String?
  trackingCode          String?
  carrier               Carrier?
  shippingAddressId     String?
  installments          Int           @default(1)
  idempotencyKey        String?       // Client-supplied key to dedupe concurrent creations
  shippedAt             DateTime?
  deliveredAt           DateTime?
  confirmedAt           DateTime?
  disputeDeadline       DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  buyer           User           @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller          User           @relation("OrderSeller", fields: [sellerId], references: [id])
  listing         Listing        @relation(fields: [listingId], references: [id])
  coupon          Coupon?        @relation(fields: [couponId], references: [id])
  shippingAddress Address?       @relation(fields: [shippingAddressId], references: [id])
  conversation    Conversation?
  reviews         Review[]
  dispute         Dispute?
  notaFiscal      NotaFiscal?
  paymentFlags    PaymentFlag[]
  listingSnapshot OrderListingSnapshot?

  @@unique([buyerId, idempotencyKey])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

// --- Payment Flags (flagged for manual review, e.g. amount mismatch) ---
model PaymentFlag {
  id         String    @id @default(cuid())
  orderId    String
  paymentId  String?
  reason     String    @db.Text
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([resolvedAt])
}

// --- Offers ---

model Offer {
  id        String      @id @default(cuid())
  listingId String
  buyerId   String
  amountBrl Decimal     @db.Decimal(10, 2)
  status    OfferStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

// --- Bundles ---

model Bundle {
  id       String       @id @default(cuid())
  buyerId  String
  sellerId String
  status   BundleStatus @default(OPEN)
  createdAt DateTime    @default(now())

  items BundleItem[]
}

model BundleItem {
  id        String @id @default(cuid())
  bundleId  String
  listingId String

  bundle  Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([bundleId, listingId])
}

// --- Wallet ---

model Wallet {
  id         String   @id @default(cuid())
  userId     String   @unique
  balanceBrl Decimal  @default(0) @db.Decimal(10, 2)
  pendingBrl Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  type        WalletTransactionType
  amountBrl   Decimal               @db.Decimal(10, 2)
  referenceId String?
  description String
  createdAt   DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([createdAt])
}

// Saved destination for seller payouts. We only support PIX at launch —
// additional types (TED, cross-border) can be added by extending the enum.
// The `pixKey` is the raw value the payment processor needs and is never
// returned by the API; responses always include a masked display form.
model PayoutMethod {
  id        String           @id @default(cuid())
  userId    String
  type      PayoutMethodType
  // Raw PIX key. MUST NEVER be logged or serialised to API responses.
  pixKey    String
  // Optional user-facing label, e.g. "Conta principal".
  label     String?
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  // Unique on (userId, type, pixKey) — the same canonical value could be
  // submitted as more than one `type` (e.g. a CPF string accidentally
  // labelled as PIX_RANDOM). Keeping `type` in the key prevents that
  // collision masquerading as a duplicate.
  @@unique([userId, type, pixKey])
  @@index([userId])
}

// Durable record of every wallet payout request. The WalletTransaction
// entry is the internal ledger row that debits the balance; this row is
// the outward-facing receipt — what the seller sees under "Meus saques",
// what ops updates when Mercado Pago confirms/fails the transfer, and
// what the webhook handler reconciles status changes against.
//
// Lifecycle: PENDING (created) → PROCESSING (MP accepted the call) →
// COMPLETED | FAILED. On FAILED we re-credit the wallet atomically and
// record `failureReason`. externalId is the Mercado Pago reference so
// webhooks / admin lookups can dedupe.
model PayoutRequest {
  id              String              @id @default(cuid())
  userId          String
  payoutMethodId  String
  // Snapshot of the method at request time so a later delete/edit of the
  // saved method doesn't leave an orphan payout record. The raw PIX key
  // is captured here too (it's already owned by this user and the row is
  // owned-only by construction).
  snapshotType    PayoutMethodType
  snapshotPixKey  String
  amountBrl       Decimal             @db.Decimal(10, 2)
  status          PayoutRequestStatus @default(PENDING)
  externalId      String?             @unique // MP reference (null until accepted)
  failureReason   String?
  // Reference to the wallet debit that funded this payout. On FAILED we
  // reverse the debit by creating a credit transaction that points back
  // at this id, so the ledger stays auditable.
  walletTransactionId String?         @unique
  requestedAt     DateTime            @default(now())
  processingAt    DateTime?
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
}

enum PayoutRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// --- Social ---

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

// --- Messaging ---

model Conversation {
  id             String   @id @default(cuid())
  participant1Id String
  participant2Id String
  orderId        String?  @unique
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  participant1 User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id])
  participant2 User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id])
  order        Order?    @relation(fields: [orderId], references: [id])
  messages     Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

// --- Reviews ---

model Review {
  id              String    @id @default(cuid())
  orderId         String
  reviewerId      String
  reviewedId      String
  rating          Int       // 1 or 5
  comment         String?
  sellerReply     String?   // Seller's public response to the review
  sellerReplyAt   DateTime? // When the seller replied
  createdAt       DateTime  @default(now())

  order    Order @relation(fields: [orderId], references: [id])
  reviewer User  @relation("ReviewWriter", fields: [reviewerId], references: [id])
  reviewed User  @relation("ReviewReceiver", fields: [reviewedId], references: [id])

  @@unique([orderId, reviewerId])
}

// --- Reports ---

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  targetType  String       // 'listing' | 'message' | 'user' | 'review'
  targetId    String
  reason      String       // 'spam' | 'counterfeit' | 'inappropriate' | 'fraud' | 'harassment' | 'other'
  description String?
  status      ReportStatus @default(PENDING)
  resolvedBy  String?      // admin userId
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter User @relation(fields: [reporterId], references: [id])

  @@unique([reporterId, targetType, targetId, status])
  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
}

// --- Blocks (user-to-user blocking) ---

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocker", fields: [blockerId], references: [id])
  blocked User @relation("UserBlocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// --- Account Deletion Audit (LGPD + App Store) ---

model DeletionAuditLog {
  id             String    @id @default(cuid())
  userId         String
  reason         String?
  deletedAt      DateTime  @default(now())
  hardDeletedAt  DateTime?
  dataExported   Boolean   @default(false)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([hardDeletedAt])
}

// --- Disputes ---

model Dispute {
  id          String        @id @default(cuid())
  orderId     String        @unique
  openedById  String
  reason      DisputeReason
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order    Order @relation(fields: [orderId], references: [id])
  openedBy User  @relation(fields: [openedById], references: [id])
}

// --- Listing Image Moderation Flags ---
//
// Created when Google Vision SafeSearch reports a `LIKELY` rating on
// adult / violence / racy for an uploaded image. `VERY_LIKELY` hits
// are refused outright at the upload boundary and never reach the DB.
//
// At the moment of upload we don't know what listing the image will
// attach to (the client hasn't submitted the listing yet), so the
// flag is keyed on the S3 key + uploader. If / when the image ends
// up on a real listing, a later cron can connect `listingId` by URL
// match — kept optional here so the flag is written without blocking.
//
// Admin review from /admin/image-flags:
//   - DISMISS: false-positive; flag resolved, image stays
//   - REJECT:  removes the S3 object + any listing/listingImage that
//              references the URL; notifies the uploader
model ListingImageFlag {
  id         String                 @id @default(cuid())
  uploaderId String
  imageUrl   String                 @db.Text
  s3Key      String
  findings   Json // full SafeSearch findings payload
  reason     String // human-readable one-liner for the admin queue
  status     ListingImageFlagStatus @default(PENDING)
  reviewedById String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime               @default(now())

  uploader User  @relation("ListingImageFlagUploader", fields: [uploaderId], references: [id])
  reviewer User? @relation("ListingImageFlagReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([uploaderId])
}

enum ListingImageFlagStatus {
  PENDING
  DISMISSED
  REJECTED
}

// --- CPF identity verification audit log ---
//
// Every call we make to a KYC provider (Serpro / Caf / etc.) writes a
// row here. Used for: ops triage of failed verifications, RIPD audit
// trail, and retention purge (docs/privacy/ripd.md §5).
//
// We deliberately store ONLY a SHA256 of the raw CPF — per CLAUDE.md
// §Logging, CPFs must never be persisted outside the User row. The
// hash lets ops correlate "which user tried to verify CPF X N times"
// without exposing the value.
model CpfVerificationLog {
  id          String   @id @default(cuid())
  userId      String
  cpfHash     String   @db.VarChar(64)
  provider    String // 'SERPRO' | 'CAF' | 'MP_WEBHOOK' | 'MANUAL_ADMIN'
  // Result taxonomy. Keep stable — dashboards slice on this column:
  //   VERIFIED          — CPF ATIVO + name matched
  //   NAME_MISMATCH     — CPF ATIVO but name differs from our row
  //   CPF_SUSPENDED     — Receita reports SUSPENSA
  //   CPF_CANCELED      — Receita reports CANCELADA / NULA
  //   DECEASED          — TITULAR FALECIDO
  //   PROVIDER_ERROR    — vendor returned 5xx / timeout / invalid payload
  //   CONFIG_ERROR      — our side: missing env / flag off
  result      String   @db.VarChar(32)
  attemptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, attemptedAt])
  @@index([cpfHash])
  @@index([attemptedAt])
}

// --- Caf document + liveness verification sessions ---
//
// Track C of the KYC plan. When Serpro (Track B) returns
// NAME_MISMATCH, CPF_SUSPENDED, or the user disputes an outcome,
// we escalate to Caf's document + liveness flow. Caf is async:
// we create a session via their API, they return a redirect URL
// that hosts the selfie + doc capture, and they webhook us when
// the user completes. This table maps the external session id
// back to our userId when the webhook arrives.
model CafVerificationSession {
  id                String    @id @default(cuid())
  userId            String
  externalSessionId String    @unique
  status            String    @default("PENDING") @db.VarChar(16)
  // 'PENDING' until the webhook fires; then 'APPROVED' /
  // 'REJECTED' / 'EXPIRED'. Terminal states set completedAt.
  redirectUrl       String    @db.Text
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
}

// --- Fraud signals ---
//
// Rule-based first pass. A FraudRule describes a single heuristic
// (e.g. "new accounts making >N orders in W minutes"). A FraudFlag
// records that a user tripped a rule with the evidence snapshotted
// in JSON for later admin review. `action=BLOCK` rules short-circuit
// the originating call (e.g. throw from OrdersService.create);
// `action=FLAG` rules always allow the call through and just queue
// the flag.
//
// Thresholds live in the DB (not code) so ops can tune without a
// deploy: raise the velocity bar if fraud is noisy, drop it if a
// spike lands. Rule rows are also disable-able (`enabled=false`)
// which is the emergency kill-switch when a rule false-positives
// on real users.
//
// Intentionally a very small surface for launch — two rules seeded
// in the migration (NEW_ACCOUNT_VELOCITY and PAYOUT_DRAIN). Add
// more over time as patterns emerge; the code dispatches by the
// stable `code` column so seeding a new rule only requires editing
// FraudService to evaluate it.
model FraudRule {
  id            String      @id @default(cuid())
  code          String      @unique
  description   String
  threshold     Int
  windowMinutes Int
  action        FraudAction @default(FLAG)
  enabled       Boolean     @default(true)
  updatedAt     DateTime    @updatedAt
}

model FraudFlag {
  id           String          @id @default(cuid())
  userId       String
  ruleCode     String
  evidence     Json
  status       FraudFlagStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime        @default(now())

  user     User  @relation("FraudFlagSubject", fields: [userId], references: [id])
  reviewer User? @relation("FraudFlagReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

enum FraudAction {
  FLAG
  BLOCK
}

enum FraudFlagStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// --- Order Listing Snapshots ---
//
// At purchase time we freeze the listing's visible state onto the order
// so dispute resolution doesn't depend on the live Listing row. The
// seller can subsequently edit or delete their listing without the
// buyer losing the evidence of what they actually bought.
//
// CURRENT SHAPE (option B): we freeze the listing's metadata and the
// IMAGE URLs. We do NOT copy the image bytes — the URLs point at the
// same S3 keys the seller uploaded to. We rely on `ListingsService.
// remove()` refusing to soft-delete a listing while any non-terminal
// order references it, so the Listing + ListingImage rows stay alive
// and the S3 keys behind them don't get garbage-collected. Cheap, good
// enough for launch.
//
// PLANNED MIGRATION (option A) — when revenue supports ~2× image
// storage: introduce a background job that reads each snapshot row,
// fetches the bytes from the seller's S3 keys, re-uploads them under
// `orders/{orderId}/snapshots/<idx>.jpg` with AES256 SSE, and rewrites
// `imageUrls` to the new URLs. Once the rewrite is acked, the option-B
// listing-freeze in ListingsService.remove() can be relaxed so sellers
// can delete SOLD listings freely.
//
// Snapshot rows are purged when their order reaches a terminal state
// (COMPLETED / CANCELLED / REFUNDED) with no open dispute — see
// OrdersService.releaseEscrow, OrdersService.cancelByBuyer,
// OrdersCronService.autoCancelUnshippedOrders, and
// DisputesService.resolve.
model OrderListingSnapshot {
  id              String   @id @default(cuid())
  orderId         String   @unique
  listingId       String
  sellerId        String
  sellerName      String
  title           String
  description     String   @db.Text
  categoryId      String
  categoryName    String
  brandId         String?
  brandName       String?
  condition       ItemCondition
  size            String?
  color           String?
  priceBrl        Decimal  @db.Decimal(10, 2)
  shippingWeightG Int
  imageUrls       Json     @default("[]")
  capturedAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// --- Notifications ---

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json     @default("{}")
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// --- Device Tokens (Push Notifications) ---

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // 'ios' or 'android'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// --- Addresses ---

model Address {
  id           String  @id @default(cuid())
  userId       String
  label        String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String  @db.VarChar(2)
  cep          String  @db.VarChar(9)
  isDefault    Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([userId])
}

// --- Nota Fiscal (NF-e) ---

model NotaFiscal {
  id               String      @id @default(cuid())
  orderId          String      @unique
  nfeId            String?
  accessKey        String?     @db.VarChar(44)
  xml              String?     @db.Text
  pdfUrl           String?
  status           NFeStatus   @default(PENDING)
  sellerCnpj       String?
  buyerCpf         String?
  originState      String      @db.VarChar(2)
  destinationState String      @db.VarChar(2)
  icmsBrl          Decimal     @db.Decimal(10, 2)
  issBrl           Decimal     @db.Decimal(10, 2)
  totalTaxBrl      Decimal     @db.Decimal(10, 2)
  issuedAt         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// --- Promotions ---

model Promotion {
  id             String        @id @default(cuid())
  listingId      String?
  userId         String
  type           PromotionType
  startsAt       DateTime      @default(now())
  endsAt         DateTime
  pricePaidBrl   Decimal       @db.Decimal(10, 2)
  requiresDiscount Boolean     @default(false)
  createdAt      DateTime      @default(now())

  listing Listing? @relation(fields: [listingId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([endsAt])
}

// --- Saved Searches ---

model SavedSearch {
  id          String  @id @default(cuid())
  userId      String
  query       String
  filtersJson Json    @default("{}")
  notify      Boolean @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// --- Price Intelligence ---

model PriceSuggestion {
  id              String   @id @default(cuid())
  listingId       String   @unique
  suggestedBrl    Decimal  @db.Decimal(10, 2)
  basedOnCount    Int
  confidence      Float
  createdAt       DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
}

model PriceDropAlert {
  id              String    @id @default(cuid())
  listingId       String
  userId          String
  originalPriceBrl Decimal  @db.Decimal(10, 2)
  notifiedAt      DateTime?
  createdAt       DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([listingId, userId])
}

// ============================================================
// Ad System
// ============================================================

// --- Ad Partners (third-party advertisers) ---

model AdPartner {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  apiKeyHash     String   @unique // SHA256 of raw API key — never store raw
  apiKeyPrefix   String   @db.VarChar(8) // first 8 chars, for display only
  active         Boolean  @default(true)
  canReceiveData Boolean  @default(false) // LGPD: explicit consent to receive anonymized data
  webhookUrl     String?
  webhookSecret  String? // HMAC-SHA256 secret for webhook delivery
  dailyBudgetBrl Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaigns AdCampaign[]

  @@index([apiKeyHash])
}

// --- Ad Campaigns ---

model AdCampaign {
  id             String           @id @default(cuid())
  partnerId      String
  name           String
  status         AdCampaignStatus @default(DRAFT)
  targetAudience Json             @default("{}") // audience segment criteria
  budgetBrl      Decimal          @db.Decimal(10, 2)
  spentBrl       Decimal          @default(0) @db.Decimal(10, 2)
  cpmBrl         Decimal          @db.Decimal(10, 4) // cost per 1000 impressions
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  partner     AdPartner      @relation(fields: [partnerId], references: [id])
  creatives   AdCreative[]
  impressions AdImpression[]
  clicks      AdClick[]

  @@index([partnerId])
  @@index([status])
  @@index([startsAt, endsAt])
}

// --- Ad Creatives ---

model AdCreative {
  id             String   @id @default(cuid())
  campaignId     String
  title          String
  body           String?
  imageUrl       String?
  ctaText        String? // call to action label
  destinationUrl String // validated at creation (no SSRF)
  format         AdFormat
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  campaign    AdCampaign     @relation(fields: [campaignId], references: [id])
  impressions AdImpression[]
  clicks      AdClick[]

  @@index([campaignId])
}

// --- Ad Impressions (shown to user) ---

model AdImpression {
  id         String   @id @default(cuid())
  campaignId String
  creativeId String
  userId     String? // null for anonymous sessions
  deviceId   String? // hashed device fingerprint
  placement  String // 'dashboard', 'search', 'listing', 'feed'
  costBrl    Decimal  @db.Decimal(10, 6)
  ipHash     String   @db.VarChar(64) // SHA256(IP) — never store raw IP
  createdAt  DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id])
  creative AdCreative @relation(fields: [creativeId], references: [id])

  @@index([campaignId, createdAt])
  @@index([userId])
  @@index([deviceId])
  @@index([createdAt])
}

// --- Ad Clicks (with bot/fraud scoring) ---

model AdClick {
  id            String   @id @default(cuid())
  campaignId    String
  creativeId    String
  impressionId  String?
  userId        String?
  deviceId      String?
  ipHash        String   @db.VarChar(64)
  botScore      Float    @default(0) // 0.0–1.0; ≥0.7 treated as bot
  isBot         Boolean  @default(false)
  fraudSignals  Json     @default("{}") // structured signals for audit
  msToClick     Int? // milliseconds from impression to click (frontend supplied)
  createdAt     DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id])
  creative AdCreative @relation(fields: [creativeId], references: [id])

  @@index([campaignId, createdAt])
  @@index([isBot])
  @@index([userId])
  @@index([ipHash, createdAt])
}

// --- User Behaviour Events (first-party data) ---

model UserEvent {
  id         String        @id @default(cuid())
  userId     String? // null for anonymous
  sessionId  String // anonymous session UUID
  deviceId   String? // hashed device fingerprint
  eventType  UserEventType
  entityType String? // 'listing', 'category', 'brand', 'seller'
  entityId   String?
  metadata   Json          @default("{}")
  ipHash     String        @db.VarChar(64)
  createdAt  DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([deviceId])
  @@index([eventType, createdAt])
  @@index([entityType, entityId])
}

// --- Personalised Ad Profile (computed from events) ---

model UserAdProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  categoryScores  Json     @default("{}") // categoryId -> float score
  brandScores     Json     @default("{}") // brandId -> float score
  priceRangeLow   Decimal? @db.Decimal(10, 2)
  priceRangeHigh  Decimal? @db.Decimal(10, 2)
  preferredSizes  String[]
  preferredColors String[]
  activeHours     Json     @default("{}") // hour (0-23) -> event count
  interestTags    String[]
  lastComputedAt  DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// --- Cross-device Linking ---

model DeviceLink {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String // SHA256(raw fingerprint)
  platform    String // 'ios', 'android', 'web'
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
}

// --- LGPD Consent Records ---

model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  consentType ConsentType
  granted     Boolean
  ipHash      String      @db.VarChar(64)
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?

  @@index([userId, consentType])
  @@index([userId])
}

// --- Login Events (security / anomaly detection) ---

model LoginEvent {
  id           String   @id @default(cuid())
  userId       String
  ipHash       String   @db.VarChar(64) // SHA256 of IP, never raw
  deviceIdHash String?  @db.VarChar(64) // SHA256 of device fingerprint
  platform     String?  // 'ios', 'android', 'web'
  success      Boolean  // false = wrong password attempt
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, success])
}

// --- Authenticity Badge Requests ---

model AuthenticityRequest {
  id             String              @id @default(cuid())
  listingId      String              @unique
  sellerId       String
  proofImageUrls String[]            // S3 URLs of uploaded proof photos (receipts, tags, care labels)
  status         AuthenticityStatus  @default(PENDING)
  reviewNote     String?             // Admin note on approval/rejection
  reviewedBy     String?             // Admin user ID who processed the request
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller  User    @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
}

