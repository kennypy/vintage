S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
PRESIGNED_URL_EXPIRY=3600

# Payments (Mercado Pago)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Shipping (Correios)
CORREIOS_API_URL=""
