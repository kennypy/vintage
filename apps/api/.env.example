# ===================================================================
# Vintage.br API — environment variables
# ===================================================================
# See DEPLOYMENT.md (repo root) for provider-by-provider instructions
# on how to obtain the production values for every variable below.
#
# Variables under "Required in production" cause startup to FAIL if
# they are missing or use the placeholder value CHANGE_ME_IN_PRODUCTION.
# Variables under "Optional in production" only disable the related
# feature when missing (startup still succeeds).
# ===================================================================

# ===================================================================
# Required in production (startup will fail without these)
# ===================================================================

# Database (Supabase, session mode for migrations, transaction mode for app)
# Production format: postgresql://postgres.<ref>:<pwd>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# SECURITY: production startup fails if sslmode= is not require / verify-ca / verify-full.
DATABASE_URL="postgresql://vintage:vintage@localhost:5434/vintage_dev?schema=public"

# Postgres connection pool ceilings. Keep DATABASE_POOL_MAX * api_instance_count
# strictly below the Postgres server's max_connections (Supabase free = 60).
# DATABASE_STATEMENT_TIMEOUT_MS kills runaway queries (default 30s, matches the
# API's request timeout). Override only to tune a specific deployment.
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000

# Auth — generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# CPF-at-rest vault keys. Required in production. Generate with:
#   openssl rand -hex 32      # 64 hex chars each
# Must be DIFFERENT values from each other (the boot-time guard
# refuses to start if they're equal — shared key defeats the
# defence-in-depth between encryption and lookup hashing).
# Rotation: requires a re-encrypt migration — not a drop-in swap.
# See apps/api/src/common/services/cpf-vault.service.ts.
CPF_ENCRYPTION_KEY="CHANGE_ME_IN_PRODUCTION"
CPF_LOOKUP_KEY="CHANGE_ME_IN_PRODUCTION"

# /metrics scrape token — gates the Prometheus scrape endpoint.
# Prometheus scrape config presents this as `X-Metrics-Token`.
# If unset, the endpoint is DISABLED (returns 401). Generate with:
#   openssl rand -hex 32
METRICS_TOKEN=""

# Optional cookie domain for the HttpOnly session cookie (vintage_session)
# the API sets after login. When unset, the cookie is scoped to the API
# host only — correct when the web app and the API share a registrable
# domain (e.g. vintage.br + api.vintage.br) and the browser sends the
# cookie on same-site fetches. Set to a leading-dot domain (".vintage.br")
# to share the cookie across multiple subdomains, but only do that when
# you're sure NO untrusted subdomain exists.
COOKIE_DOMAIN=""
# CSRF — generate with: openssl rand -hex 32
CSRF_SECRET="CHANGE_ME_IN_PRODUCTION"

# App runtime
NODE_ENV="development"
PORT=3001
# Comma-separated allowlist. Production example:
#   CORS_ORIGIN="https://vintage.br,https://www.vintage.br"
CORS_ORIGIN="http://localhost:3000"

# Fallback single origin for the Socket.IO gateway (/chat namespace) when
# neither CORS_ORIGIN nor the historical CORS_ORIGINS plural is set. Leave
# blank in production — CORS_ORIGIN is the canonical var and the gateway
# falls back to [] (reject-all) if nothing resolves. See
# apps/api/src/messages/messages.gateway.ts:parseCorsOrigins.
WEB_URL=""

# Number of reverse-proxy hops in front of the API. Express' `trust proxy`
# setting tells the framework how many X-Forwarded-For entries to trust when
# resolving req.ip (used by the rate limiter, CAPTCHA, and audit logs).
#   0 — API is exposed directly (local dev)
#   1 — Fly.io / single proxy (production default)
#   2 — Cloudflare in front of Fly
# Setting too high lets attackers spoof their IP via X-Forwarded-For.
# Setting too low collapses every request into the proxy's bucket (DoS).
TRUSTED_PROXY_HOPS=0

# Terms-of-service version shown/accepted by users
TOS_VERSION="1.0.0"

# Redis (Upstash, TLS) — production format: rediss://default:<pwd>@<host>.upstash.io:6379
# REDIS_PASSWORD (or credentials embedded in REDIS_URL) is MANDATORY in production.
REDIS_URL="redis://localhost:6380"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6380"
# Optional if REDIS_URL already contains password, but some clients read it separately
REDIS_PASSWORD=""

# Image upload allowlist — comma-separated list of hostnames permitted as
# listing imageUrl values. Extend this when adding a CDN in front of S3.
# Leave blank to fall back to picsum.photos (dev) and the S3 bucket's
# virtual-hosted-style URLs (production).
ALLOWED_IMAGE_HOSTS=""

# Storage (Cloudflare R2, S3-compatible)
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET="vintage-images"
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
PRESIGNED_URL_EXPIRY=3600

# Payments (Mercado Pago)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Shipping (Correios)
CORREIOS_API_URL=""
CORREIOS_TOKEN=""

# Shipping (Jadlog) — secondary carrier. Optional: when JADLOG_TOKEN is
# unset the Jadlog client logs a warning and falls back to mock rates /
# labels / tracking so local dev and CI keep working. Set in production
# so real labels and tracking codes are returned. JADLOG_API_URL only
# needs to be set if the vendor moves the endpoint; the default tracks
# the public production URL.
JADLOG_TOKEN=""
JADLOG_API_URL="https://www.jadlog.com.br/api"

# Shipping (Kangu) — pickup-point network used as a dropoff-friendly
# alternative to Correios/Jadlog. Mocks rates + labels until the real
# KANGU_API_KEY is set (same degradation pattern as Jadlog).
KANGU_API_KEY=""
KANGU_API_URL="https://portal.kangu.com.br/tms/transporte"

# Shipping (Pegaki) — second pickup-point network. Same mock-until-
# configured pattern as Kangu/Jadlog.
PEGAKI_API_KEY=""
PEGAKI_API_URL="https://api.pegaki.com.br/v1"

# NF-e (eNotas / NFe.io)
NFE_API_KEY=""
NFE_API_URL="https://api.enotas.com.br/v2"

# ===================================================================
# Optional in production (features degrade gracefully without these)
# ===================================================================

# Meilisearch (Meilisearch Cloud or self-hosted on Fly.io)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="vintage_dev_key"

# Email (Resend via SMTP)
# Production: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USER=resend, SMTP_PASS=<resend api key>
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Vintage.br <noreply@vintage.br>"
# Alias kept for backwards compatibility with older code paths
EMAIL_FROM="Vintage.br <noreply@vintage.br>"

# Firebase (Push Notifications) — JSON-encoded service account key
FIREBASE_SERVICE_ACCOUNT_JSON=""

# SMS / 2FA (Twilio)
# Get from console.twilio.com → Account Info (SID + Auth Token)
# and Phone Numbers → Manage → Buy a number (From number, E.164 format).
# Leave blank in development — SMS will be logged to console instead of sent.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Mercado Pago PIX payout integration (Wave 3C)
# Flip to "true" ONLY after the MP Marketplace / Money-Out contract is
# active for your CNPJ. While "false", /wallet/payout creates a
# PayoutRequest in PENDING status and the finance team processes PIX
# out-of-band, then flips status via the admin endpoint. See
# THIRD_PARTY_ONBOARDING §1.5.
MERCADOPAGO_PAYOUT_ENABLED="false"

# Social Login (Google)
# GOOGLE_CALLBACK_URL is the one OAuth sends the user back to after the
# Google sign-in screen. If GOOGLE_CALLBACK_URL is unset, google.strategy.ts
# derives the callback from API_URL (see below) as a dev-only fallback —
# production MUST set GOOGLE_CALLBACK_URL explicitly so the URL matches
# what's registered in Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# Public origin of this API (no trailing slash). Used as a fallback base
# when GOOGLE_CALLBACK_URL is not set, and by identity.service.ts as a
# fallback for WEBHOOK_BASE_URL (Caf KYC callbacks). Setting the two more
# specific vars is preferred; this is only the last-resort default.
API_URL=""
API_PUBLIC_URL=""

# Social Login (Apple) — not required for Android-only launch
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Google Vision (image analysis + SafeSearch moderation)
# Adds LABEL_DETECTION / LOGO_DETECTION / WEB_DETECTION / IMAGE_PROPERTIES /
# TEXT_DETECTION / SAFE_SEARCH_DETECTION. When unset, uploads skip both
# autofill and moderation (fail-open for launch — tighten post-launch).
GOOGLE_VISION_API_KEY=""

# Cloudflare Turnstile (captcha on register / forgot-password / SMS resend)
# Obtain a site key + secret at https://dash.cloudflare.com/?to=/:account/turnstile
# CAPTCHA_ENFORCE toggles enforcement on the three guarded endpoints. Leave
# "false" while the mobile app release without captcha-token support is still
# in the wild; flip to "true" once >=95% of mobile traffic is on a version
# that sends captchaToken. TURNSTILE_SECRET_KEY is server-side; the web site
# key lives in apps/web/.env.example as NEXT_PUBLIC_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=""
CAPTCHA_ENFORCE="false"

# Analytics (PostHog, EU region for LGPD residency)
# POSTHOG_API_KEY=""  → every capture() is a no-op
# POSTHOG_HOST defaults to https://eu.i.posthog.com — only override for self-
# hosted or the US region.
POSTHOG_API_KEY=""
POSTHOG_HOST="https://eu.i.posthog.com"

# Universal Links + Android App Links
# APPLE_TEAM_ID is ALREADY declared above in the Social Login (Apple) block
# and is reused by /.well-known/apple-app-site-association on the web host.
# IOS_BUNDLE_ID defaults to br.vintage.app (matches apps/mobile/app.json).
# ANDROID_PACKAGE defaults to br.vintage.app.
# ANDROID_CERT_SHA256: colon-separated uppercase, 95 chars. Obtain from
# Play Console → Release → Setup → App Integrity → App Signing Certificate.
# Comma-separate multiple fingerprints (debug + release) during rollout.
IOS_BUNDLE_ID="br.vintage.app"
ANDROID_PACKAGE="br.vintage.app"
ANDROID_CERT_SHA256=""

# Tracking poller cron (auto-flip SHIPPED → DELIVERED when the carrier
# reports a delivered event). Defaults below are production-sane; override
# only to narrow the lookback window or cap quota usage on a new carrier
# integration.
TRACKING_POLL_LOOKBACK_DAYS="30"
TRACKING_POLL_BATCH_SIZE="200"

# Listings lifecycle crons
# STALE_LISTING_DAYS: ACTIVE → PAUSED after N days without any update
# PAUSED_CLEANUP_DAYS: PAUSED → DELETED after N days of continued inactivity
STALE_LISTING_DAYS="90"
PAUSED_CLEANUP_DAYS="180"

# Retention purges (launch-day crons — see apps/api/src/common/crons/)
# Units are days. Defaults match docs/privacy/ripd.md §5.
RETENTION_LOGIN_EVENT_DAYS="90"
RETENTION_PROCESSED_WEBHOOK_DAYS="30"
RETENTION_LISTING_IMAGE_FLAG_DAYS="365"
RETENTION_FRAUD_FLAG_DAYS="365"

# S3 orphan sweep — delete S3 keys attached to listings whose status has
# been DELETED for at least this many days. Set conservatively: deletes are
# irreversible.
ORPHAN_IMAGE_SWEEP_DAYS="30"

# Identity verification (Serpro Datavalid — Track B of the KYC plan)
# Off until the Serpro contract is active. When IDENTITY_VERIFICATION_ENABLED
# is "false", POST /users/me/verify-identity returns CONFIG_ERROR and
# every user's cpfIdentityVerified stays false — which blocks payouts.
# Once SERPRO_CLIENT_ID / SERPRO_CLIENT_SECRET are provisioned and the
# base URL is confirmed in the contract, flip the flag to true.
#
#   SERPRO_BASE_URL       — from the Serpro contract (production vs staging)
#   SERPRO_TOKEN_PATH     — defaults to /token; only override if the
#                           contract specifies a different OAuth endpoint
#   SERPRO_VALIDATE_PATH  — defaults to /datavalid/v3/validate
#   SERPRO_CLIENT_ID      — issued by Serpro on contract activation
#   SERPRO_CLIENT_SECRET  — issued by Serpro on contract activation
IDENTITY_VERIFICATION_ENABLED="false"
SERPRO_BASE_URL=""
SERPRO_TOKEN_PATH="/token"
SERPRO_VALIDATE_PATH="/datavalid/v3/validate"
SERPRO_CLIENT_ID=""
SERPRO_CLIENT_SECRET=""

# Identity-verification reminder cadence (see IdentityReminderCron).
# Comma-separated list of hours-past-signup at which an un-verified
# user should be nudged. The cron de-dupes on (userId, step) so running
# hourly is safe. Default below mirrors the in-code default.
# Set to the empty string to disable the reminder entirely.
IDENTITY_REMINDER_CADENCE_HOURS="24,72,168"

# CpfVerificationLog retention (see docs/privacy/ripd.md §5). One row
# per KYC attempt. Keep long enough for fraud-pattern analysis but
# purge before it becomes an LGPD liability.
RETENTION_CPF_VERIFICATION_LOG_DAYS="365"

# Identity verification Track C — Caf document + liveness.
# Escalation path when Serpro returns NAME_MISMATCH / CPF_SUSPENDED,
# or when a user disputes the Track-B outcome.
#
# IDENTITY_DOCUMENT_ENABLED flips this on. Independent of
# IDENTITY_VERIFICATION_ENABLED (Serpro) — the two vendor contracts
# can activate on different timelines.
#
#   CAF_BASE_URL              — from the Caf contract (prod vs sandbox)
#   CAF_CREATE_SESSION_PATH   — defaults /v1/verifications; only override
#                               if the contract specifies a different path
#   CAF_API_KEY               — issued by Caf on contract activation
#   CAF_WEBHOOK_SECRET        — HMAC-SHA256 shared secret. Required.
#                               Without it, every inbound webhook is
#                               refused (never trust-by-default).
#
# WEBHOOK_BASE_URL is the public origin Caf will POST back to. In
# dev, forward via a tunnel (ngrok / cloudflared); in prod, set to
# https://api.vintage.br.
IDENTITY_DOCUMENT_ENABLED="false"
CAF_BASE_URL=""
CAF_CREATE_SESSION_PATH="/v1/verifications"
CAF_API_KEY=""
CAF_WEBHOOK_SECRET=""
WEBHOOK_BASE_URL=""

# CafVerificationSession retention — one row per Caf session. Purged
# alongside the other identity logs.
RETENTION_CAF_SESSION_DAYS="365"

# Admin bootstrap — one-shot secret used by POST /auth/admin/setup to
# promote the very first admin account on a fresh deployment. Leave
# UNSET in day-to-day operation: without it the endpoint returns 400
# and cannot be used. Set it once during initial provisioning, run the
# bootstrap, then unset it (or rotate the value) so the endpoint is
# disabled again. The in-code compare is constant-time (timingSafeEqual)
# to close the byte-by-byte timing oracle reported as pen-test A-10.
# See apps/api/src/auth/auth.service.ts :: adminSetup.
# Generate with: openssl rand -hex 32
ADMIN_SETUP_KEY=""

# ── Escrow hold window ─────────────────────────────────────────────────
# Buffer between buyer confirming receipt (or auto-confirm cron firing)
# and funds landing in the seller's withdrawable balance. During the
# hold, the buyer can still open a dispute or request a return and
# the releaseHeldEscrow cron will skip the order. 0 = no hold (funds
# release on confirmation, matching the legacy behaviour). Increase
# to defend a longer chargeback window.
ESCROW_HOLD_DAYS="2"

# ── Returns ────────────────────────────────────────────────────────────
# RETURN_WINDOW_DAYS: how long after deliveredAt a buyer may open a
# return request. RETURN_INSPECTION_DAYS: deadline after the package
# is marked RECEIVED for the seller to inspect before the return
# auto-escalates to a Dispute so the buyer isn't stuck.
RETURN_WINDOW_DAYS="7"
RETURN_INSPECTION_DAYS="3"

# ── Listing KYC gate ───────────────────────────────────────────────────
# When IDENTITY_VERIFICATION_ENABLED=true (above), sellers must have
# cpfIdentityVerified=true before ListingsService.create accepts their
# request. Closes the ban-evasion loop where a banned seller re-registers
# with a fresh email. Leave IDENTITY_VERIFICATION_ENABLED=false in
# markets where Serpro/CAF aren't yet provisioned — the cpfChecksumValid
# fallback still enforces Modulo-11 validity.

# ── Referrals ───────────────────────────────────────────────────────────
# Reward amount is defined as the shared constant REFERRAL_REWARD_BRL
# (10 BRL default). No env override — changing reward mid-flight would
# require user comms and is intentionally a code change, not a knob.

# ── NF-e issuer ────────────────────────────────────────────────────────
# NFE_PROVIDER selects the driver in nfe.client.ts. 'focus' = Focus NFe
# (primary), 'enotas' = legacy eNotas integration. Ops can swap without
# a deploy. NFE_API_URL defaults to the selected provider's prod host
# and can be overridden to the sandbox during testing.
NFE_PROVIDER="focus"
NFE_API_URL=""
NFE_API_KEY=""

# ── WhatsApp (Twilio) ──────────────────────────────────────────────────
# Optional — when set, transactional shipping/order alerts are sent via
# WhatsApp instead of SMS (BR users strongly prefer it for logistics).
# Format with or without the whatsapp: prefix; the client adds it when
# missing. Twilio Sandbox numbers work for dev; prod requires WhatsApp
# Business approval.
TWILIO_WHATSAPP_FROM=""

# ── Support / CRM ──────────────────────────────────────────────────────
# Integration with the ops CRM (kennypy/CRM). The CRM is the agent
# workspace — agents reply, resolve, and triage from there, not from
# Vintage's admin panel. Three pieces:
#
#   1. Outbound webhook (Vintage → CRM) — HMAC-signed with
#      SUPPORT_CRM_WEBHOOK_SECRET in X-Vintage-Signature. Emits:
#        - ticket.opened           on createTicket
#        - ticket.user_replied     on user reply to an OPEN/IN_PROGRESS ticket
#        - ticket.user_reopened    on user reply to a RESOLVED/CLOSED ticket
#      Fire-and-forget with a 5s timeout; failures land in AuditLog
#      as CRM_WEBHOOK_FAILED and the support-cron replays opens hourly.
#
#   2. Inbound partner API (CRM → Vintage) — authenticated by
#      X-Partner-Key matched against CRM_PARTNER_KEY below. Exposes:
#        - POST /partner/support/tickets/:id/reply
#        - POST /partner/support/tickets/:id/resolve
#      Both accept an Idempotency-Key header (recommended: outbound job
#      UUID). Two calls with the same key produce exactly one message
#      row, so at-least-once retries after response-side timeouts are
#      safe. Leaving CRM_PARTNER_KEY empty disables the partner
#      endpoints entirely — every request is 401'd.
#
#   3. Shared system user support@vintage.br. Lazy-created on first
#      agent reply. All CRM-originated replies are stored under this
#      user's ID; the real agent's display name ("Ana do Suporte")
#      lives on SupportTicketMessage.senderDisplayName.
#
# When all three envs are empty, tickets stay in-house and can be
# worked through /admin/support (breakglass only).
SUPPORT_CRM_WEBHOOK_URL=""
SUPPORT_CRM_WEBHOOK_SECRET=""
# 32+ char secret shared with the CRM. The guard refuses shorter values
# outright so nobody deploys with a dev string.
CRM_PARTNER_KEY=""
