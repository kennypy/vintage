# Database
DATABASE_URL="postgresql://vintage:vintage@localhost:5432/vintage_dev?schema=public"

# Auth
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# App
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# Storage (S3 / R2)
S3_BUCKET="vintage-images"
