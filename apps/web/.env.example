# Vintage.br Web — environment variables
#
# Copy to apps/web/.env.local and fill in as needed. Variables prefixed
# with NEXT_PUBLIC_ are exposed to the browser — put no secrets there.
#
# Server-side env vars (no NEXT_PUBLIC_) live on the host / CI. The
# /.well-known/* route handlers read them at request time.

# Base URL for SEO canonicals + open-graph. Production: https://vintage.br
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API base URL the browser (and `src/app/**/page.tsx` server renders) use
# to call the NestJS backend. Falls back to http://localhost:3001/api/v1
# when unset — a production deploy that forgets to set this will silently
# try to reach localhost from Vercel and every data-bound page will 500.
# Production: https://api.vintage.br/api/v1
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# Cloudflare Turnstile site key — paired with TURNSTILE_SECRET_KEY on the
# API. When unset, the <TurnstileWidget /> renders a dev-mode hint and the
# widget is a no-op. Set once you've provisioned a Turnstile site.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Universal Links + Android App Links — consumed by the /.well-known/
# route handlers at request time.
#   APPLE_TEAM_ID:      10-char alphanumeric from App Store Connect
#   IOS_BUNDLE_ID:      defaults to br.vintage.app
#   ANDROID_PACKAGE:    defaults to br.vintage.app
#   ANDROID_CERT_SHA256: colon-separated uppercase from Play Console
#                         → Release → Setup → App Integrity. Comma-
#                         separate multiple (debug + release) during
#                         rollout.
APPLE_TEAM_ID=""
IOS_BUNDLE_ID="br.vintage.app"
ANDROID_PACKAGE="br.vintage.app"
ANDROID_CERT_SHA256=""

# Client-side PostHog (web pageview + click events)
# Leave blank to disable — the provider short-circuits to a no-op.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
