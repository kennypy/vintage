{
  "expo": {
    "name": "Vintage.br",
    "slug": "vintage-br",
    "version": "0.0.1",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vintage",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.vintage.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Vintage.br precisa da câmera para tirar fotos dos seus itens.",
        "NSPhotoLibraryUsageDescription": "Vintage.br precisa acessar suas fotos para criar anúncios.",
        "NSFaceIDUsageDescription": "Use Face ID para acessar sua conta de forma segura."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "br.vintage.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
