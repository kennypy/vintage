{
  "expo": {
    "name": "Vintage.br",
    "slug": "vintage-br",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vintage",
    "privacyUrl": "https://vintage.br/privacidade",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#1a1a2e",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.vintage.app",
      "buildNumber": "1",
      "requireFullScreen": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["mailto", "tel", "https", "http"],
        "NSCameraUsageDescription": "O Vintage.br usa a câmera para você fotografar as peças que vai anunciar.",
        "NSPhotoLibraryUsageDescription": "O Vintage.br acessa sua galeria para você escolher fotos dos seus anúncios e sua foto de perfil.",
        "NSPhotoLibraryAddUsageDescription": "O Vintage.br pode salvar comprovantes de pagamento e QR codes PIX na sua galeria.",
        "NSFaceIDUsageDescription": "Use Face ID para entrar rapidamente e confirmar transações com segurança.",
        "NSMicrophoneUsageDescription": "O microfone é utilizado apenas para gravar vídeos curtos dos seus anúncios.",
        "NSUserTrackingUsageDescription": "Não rastreamos você em outros apps. Esta permissão só é solicitada caso você ative analytics opcional.",
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleLocalizations": ["pt-BR", "pt", "en"],
        "CFBundleDevelopmentRegion": "pt-BR"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "br.vintage.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_SMS",
        "android.permission.QUERY_ALL_PACKAGES",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "allowBackup": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "O Vintage.br usa a câmera para você fotografar as peças que vai anunciar."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Vintage.br acessa sua galeria para você escolher fotos dos seus anúncios e sua foto de perfil.",
          "cameraPermission": "O Vintage.br usa a câmera para você fotografar as peças que vai anunciar."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1a1a2e",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID para entrar rapidamente e confirmar transações com segurança."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bec14fac-3828-4d4c-9941-26fd182865f0"
      }
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/bec14fac-3828-4d4c-9941-26fd182865f0"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
