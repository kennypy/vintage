# Vintage.br Mobile — Environment Variables
#
# Copy this file to .env and update values for your environment.
#
# IMPORTANT: On physical devices (Expo Go), localhost does NOT work.
# Use your computer's LAN IP address instead.
#
# To find your LAN IP:
#   macOS/Linux: ifconfig | grep "inet " | grep -v 127.0.0.1
#   Windows:     ipconfig | findstr /i "IPv4"
#
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3001/api/v1
#
# For Expo tunnel mode (npx expo start --tunnel), use the tunnel URL.

EXPO_PUBLIC_API_URL=http://192.168.1.100:3001/api/v1
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Build-mode flag read by apps/mobile/src/services/api.ts:5. When set to
# exactly "production", the mobile app refuses to fall back to the
# localhost API URL and refuses to talk to the API over plaintext http://.
# EAS build profiles in eas.json (development / preview / production) set
# this automatically — only override locally when you want `npx expo
# start` to simulate production. Any value that is not the literal string
# "production" is treated as dev.
EXPO_PUBLIC_ENV=development

# Cloudflare Turnstile site key (same value as NEXT_PUBLIC_TURNSTILE_SITE_KEY
# on the web). Mobile shows a WebView-hosted Turnstile challenge before
# submitting register / forgot-password / SMS-resend. Leave blank to skip the
# widget in dev — as long as the API runs with CAPTCHA_ENFORCE=false, calls
# succeed without a token.
EXPO_PUBLIC_TURNSTILE_SITE_KEY=

# Client-side PostHog (mobile screen focus + lifecycle events).
# Leave blank to disable.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
