{
  "name": "vintage-br",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "metro": "~0.82.0",
    "metro-runtime": "~0.82.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "overrides": {
    "react-test-renderer": "19.1.0",
    "expo-file-system": "~19.0.21"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@types/qrcode": "1.5.6",
    "otplib": "13.4.0",
    "qrcode": "1.5.4"
  }
}
