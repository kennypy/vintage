# Optional local override file for docker-compose.
# Copy to .env.docker (which is gitignored) and customize before `docker compose up`.
# Values here are only used by the docker-compose stack — NOT by the API itself.

# Postgres
POSTGRES_USER=vintage
POSTGRES_PASSWORD=vintage
POSTGRES_DB=vintage_dev

# Redis — MUST be a strong password in anything other than local dev.
REDIS_PASSWORD=vintage_dev_redis_pw

# Meilisearch
MEILI_MASTER_KEY=vintage_dev_key
MEILI_ENV=development
